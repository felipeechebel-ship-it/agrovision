# Copia este archivo como .env y completá los valores

# Google Gemini (obligatorio)
# Obtené tu key en: https://aistudio.google.com/apikey
GEMINI_KEY=AIza...

# Gemini model (opcional, por defecto gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Planet Labs (opcional — si no lo ponés, las capas Planet no aparecen)
# Obtené tu key en: https://www.planet.com/account/#/user-settings
PLANET_KEY=

# Puerto local (Railway lo sobreescribe automáticamente)
PORT=3000
